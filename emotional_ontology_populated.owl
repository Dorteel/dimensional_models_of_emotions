<owl:NamedIndividual rdf:about="#anger">
  <rdf:type rdf:resource="#Emotion"/>
  <orka:describedBy rdf:resource="#https_dictionary_apa_org_anger"/>
  <orka:describedBy rdf:resource="#https_github_com_aesuli_sentiwordnet_blob_master_data_sentiwordnet_3_0_0_txt"/>
  <orka:describedBy rdf:resource="#https_dictionary_cambridge_org_dictionary_english_anger"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anger</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">synset: 14036539</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">apa_definition: an emotion characterized by tension and hostility arising from frustration, real or imagined injury by another, or perceived injustice. It can manifest itself in behaviors designed to remove the object of the anger (e.g., determined action) or behaviors designed merely to express the emotion (e.g., swearing).</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sentiwordnet_definition: the state of being angry</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cambridge_definition: a strong feeling that makes you want to hurt someone or be unpleasant because of something unfair or unkind that has happened</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#anger_apa_definition">
  <rdf:type rdf:resource="#Definition"/>
  <hasSource rdf:resource="#https_dictionary_apa_org_anger"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#string">an emotion characterized by tension and hostility arising from frustration, real or imagined injury by another, or perceived injustice. It can manifest itself in behaviors designed to remove the object of the anger (e.g., determined action) or behaviors designed merely to express the emotion (e.g., swearing).</hasValue>
</owl:NamedIndividual>

