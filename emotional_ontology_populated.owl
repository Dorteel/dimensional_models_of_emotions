<owl:NamedIndividual rdf:about="#acceptance">
  <rdf:type rdf:resource="#Emotion"/>
  <orka:describedBy rdf:resource="#https_github_com_aesuli_sentiwordnet_blob_master_data_sentiwordnet_3_0_0_txt"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acceptance</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">synset: 4638175</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">apa_definition: a favorable attitude toward an idea, situation, person, or group. In the context of psychotherapy and counseling, it is the receptive, nonjudgmental attitude of therapists or counselors, which conveys an implicit respect and regard for their clients as individuals.</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sentiwordnet_definition: a disposition to tolerate or accept people or situations; \"all people should practice toleration and live together in peace\"</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cambridge_definition: general agreement that something is satisfactory or right, or that someone should be included in a group</rdfs:comment>
</owl:NamedIndividual>

